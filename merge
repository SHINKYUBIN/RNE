    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 720)








    #csv_header = (
        #"filename", "similarity",
        #"R_id", "R_conf", "R_fx", "R_fz", "R_vec",
        #"L_id", "L_conf", "L_fx", "L_fz", "L_vec",
