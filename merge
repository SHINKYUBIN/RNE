# --- 3.2 Kinematics Logic ---
@dataclass
class KinematicsResult:
    theta0: float
    vec: float
    L4: float
    theta2prime: float
    theta4: float








def calculate_kinematics_data(fx: float, fz: float, vec: float) -> Optional[KinematicsResult]:
    # Step 1: Base Rotation
    dx_base = fx - REF_AX
    dz_base = fz - REF_AZ
    theta0_rad = math.atan2(dx_base, dz_base)
    theta0 = math.degrees(theta0_rad)








    # Step 2: 3D to 2D
    horizontal_dist = math.sqrt(dx_base**2 + dz_base**2)
    target_r = horizontal_dist
    target_y = FY_CONST








    # Step 3: Planar IK
    dist_x = BX - target_r
    dist_y = BY - target_y
    L3 = math.sqrt(dist_x**2 + dist_y**2)








    if L3 > (L1 + L2) or L3 < abs(L1 - L2) or L3 == 0:
        return None








    try:
        cos_th4 = (L1**2 + L2**2 - L3**2) / (2 * L1 * L2)
        cos_th4 = max(-1.0, min(1.0, cos_th4))
        th4_rad = math.acos(cos_th4)








        beta = math.atan2(dist_y, dist_x)
        cos_alpha = (L3**2 + L1**2 - L2**2) / (2 * L3 * L1)
        cos_alpha = max(-1.0, min(1.0, cos_alpha))
        alpha = math.acos(cos_alpha)








        th2_prime_rad = beta - alpha








        p1_x = BX - L1 * math.cos(th2_prime_rad)
        p1_y = BY - L1 * math.sin(th2_prime_rad)
        L4 = math.sqrt((AX - p1_x)**2 + (AY - p1_y)**2)








    except ValueError:
        return None








    return KinematicsResult(
        theta0=theta0,
        vec=vec,
        L4=L4,
        theta2prime=math.degrees(th2_prime_rad),
        theta4=math.degrees(th4_rad)
    )








# --- 3.3 Motor Control Logic ---
def _execute_motion(servo_targets, dc_motor=None, dc_target_len=None, dc_current_len_key=None):
    if kit is None: return
   
    # 1. Calc Servo Time
    max_servo_time = 0
    for name, target_angle in servo_targets.items():
        curr_angle = current_state[name]
        needed_time = abs(target_angle - curr_angle) * SERVO_SEC_PER_DEG
        if needed_time > max_servo_time: max_servo_time = needed_time








    # 2. Calc DC Time
    dc_time, diff_len = 0, 0
    if dc_motor and dc_target_len is not None:
        curr_len = current_state[dc_current_len_key]
        diff_len = dc_target_len - curr_len
        dc_time = abs(diff_len) / DC_SPPEED_PIX_PER_SEC
    








    # 3. Total Duration
    total_duration = max(max_servo_time, dc_time)
    if total_duration < 0.1: total_duration = 0.1








    # 4. DC PWM
    dc_pwm, actual_dc_run_time = 0, 0
    if dc_motor and dc_time > 0:
        ratio = dc_time / total_duration
        dc_pwm = min(max(ratio, 0.0), 1.0)
        actual_dc_run_time = total_duration








    print(f"Motion: {total_duration:.2f}s (DC PWM: {dc_pwm:.2f})")








    # Execution
    if dc_motor and abs(diff_len) > 0.01:
        dc_motor.forward(speed=dc_pwm) if diff_len > 0 else dc_motor.backward(speed=dc_pwm)








    for name, target_angle in servo_targets.items():
        safe_angle = max(0, min(180, target_angle))
        kit.servo[SERVO_MAP[name]].angle = safe_angle
        current_state[name] = safe_angle








    if actual_dc_run_time < total_duration:
        time.sleep(actual_dc_run_time)
        if dc_motor: dc_motor.stop()
        time.sleep(total_duration - actual_dc_run_time)
    else:
        time.sleep(total_duration)
        if dc_motor: dc_motor.stop()
   
    if dc_target_len is not None:
        current_state[dc_current_len_key] = dc_target_len








def move_group_s1_d2(target_angle_s1):
    delta_angle = target_angle_s1 - current_state['s1']
    spool_radius_cm = SPOOL_RADIUS_MM / 10.0
    delta_len_cm = (2 * math.pi * spool_radius_cm) * (delta_angle / 360.0)
    target_len_d2 = current_state['d2'] + delta_len_cm
   
    print(f"[G1] s1:{target_angle_s1:.1f}, d2:{target_len_d2:.2f}")
    _execute_motion({'s1': target_angle_s1}, motor_d2, target_len_d2, 'd2')








def move_group_s2_s3(target_angle_s2, target_angle_s3):
    print(f"[G2] s2:{target_angle_s2:.1f}, s3:{target_angle_s3:.1f}")
    _execute_motion({'s2': target_angle_s2, 's3': target_angle_s3})








def move_group_s4_s5_d1(target_angle_s4, target_angle_s5, target_len_d1_cm):
    print(f"[G3] s4:{target_angle_s4:.1f}, s5:{target_angle_s5:.1f}, d1:{target_len_d1_cm:.2f}")
    _execute_motion({'s4': target_angle_s4, 's5': target_angle_s5}, motor_d1, target_len_d1_cm, 'd1')








def move_group_s6(target_angle_s6):
    print(f"[G4] s6:{target_angle_s6:.1f}")
