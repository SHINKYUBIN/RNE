    print("\n=== READY ===")
    print(" [c] Capture -> Process -> Move Robot")
    print(" [q] Quit")
   
    try:
        while True:
            ret, frame = cap.read()
            if not ret: break








            vis_frame = frame.copy()
            if USE_ROI_CROP:
                cv2.rectangle(vis_frame, (ROI_X1, ROI_Y1), (ROI_X2, ROI_Y2), (0, 255, 0), 2)
                cv2.putText(vis_frame, "ROI", (ROI_X1, ROI_Y1-10), cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0,255,0), 2)
           
            cv2.imshow('Webcam', vis_frame)
