# --- 3.1 Vision Helpers ---
def resolve_class_ids(yolo_model, left_key='left', right_key='right', hole_key='hold'):
    """
    YOLO 모델의 클래스 이름에서 ID를 찾습니다.
    학습된 모델이 'hold'를 사용하므로 기본값(default)을 'hold'로 설정했습니다.
    """
    names = yolo_model.model.names if hasattr(yolo_model.model, 'names') else {}
    norm = {str(v).replace(' ', '').lower(): int(k) for k, v in names.items()}
    lk, rk, hk = left_key.replace(' ', '').lower(), right_key.replace(' ', '').lower(), hole_key.replace(' ', '').lower()
    return names, norm.get(lk), norm.get(rk), norm.get(hk, -999)








