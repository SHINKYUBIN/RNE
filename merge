def reset_to_zero():
    print(">>> Returning to INITIAL STATE...")
    move_group_s7(zero_state['s7'])
    move_group_s4_s5_d1(zero_state['s4'], zero_state['s5'], zero_state['d1'])
    move_group_s2_s3(zero_state['s2'], zero_state['s3'])
    move_group_s1_d2(zero_state['s1'])
    move_group_s6(zero_state['s6']) # Reset gripper








def execute_robot_task_sequence(kin: KinematicsResult):
    print(f"\n>>> Executing Sequence for Theta0: {kin.theta0:.2f}")
   
    # 1. Base Rotation
    move_group_s1_d2(target_angle_s1=kin.theta0)
    time.sleep(0.5)








    # 2. Shoulder
    move_group_s2_s3(target_angle_s2=180 - kin.theta2prime, target_angle_s3=kin.theta2prime)
    time.sleep(0.5)








    # 3. Elbow & Arm Extension
    move_group_s4_s5_d1(target_angle_s4=180 - kin.theta4, target_angle_s5=kin.theta4, target_len_d1_cm=kin.L4)
    time.sleep(0.5)








    # 4. End Effector Orient
    vec_deg = math.degrees(kin.vec)
    move_group_s7(target_angle_s7=vec_deg)
   
    # 5. Gripper Action
    move_group_s6(target_angle_s6=100)
    time.sleep(0.5)
   
    # 6. Reset (Grip and Return)
    # move_group_s6(0) # 필요시 그리퍼를 다시 풀거나 유지
    time.sleep(0.5)
    reset_to_zero()








