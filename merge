            if key == ord('q'):
                break
           
            elif key == ord('c'):
                # -------------------------
                # 1. Vision Processing
                # -------------------------
                if USE_ROI_CROP:
                    h, w = frame.shape[:2]
                    x1, y1 = max(0, ROI_X1), max(0, ROI_Y1)
                    x2, y2 = min(w, ROI_X2), min(h, ROI_Y2)
                    process_frame = frame[y1:y2, x1:x2].copy()
                    offset_x, offset_y = x1, y1
                else:
                    process_frame = frame.copy()
                    offset_x, offset_y = 0, 0
               
                if process_frame.size == 0: continue
               
                pil_img = Image.fromarray(cv2.cvtColor(process_frame, cv2.COLOR_BGR2RGB))
                ts = time.strftime("%Y%m%d_%H%M%S")
                fname = f"capture_{num}_{ts}"
                print(f"\n--- Processing {fname} ---")








                # YOLO Predict
                res = yolo.predict(process_frame, conf=CONF_MIN, imgsz=IMG_SIZE, iou=IOU_NMS, verbose=False)[0]
                if getattr(res, "obb", None) is None or len(res.obb) == 0:
                    print("No detections.")
                    continue








                xywhr = res.obb.xywhr.detach().cpu().numpy()
                cls_ids = res.obb.cls.detach().cpu().numpy().astype(int)
                confs = res.obb.conf.detach().cpu().numpy()
               
                shoes_r, shoes_l, holes = [], [], []








                for k, (c, cf, obb) in enumerate(zip(cls_ids, confs, xywhr)):
                    if cf < CONF_MIN: continue
                    cx, cy, w, h, th = map(float, obb)
                    corners = obb_corners_from_xywhr(cx, cy, w, h, th)
                    gx, gy = cx + offset_x, cy + offset_y
                   
                    item_data = {
                        'obb': (cx, cy, w, h, th), 'corners': corners,
                        'cx': cx, 'cy': cy, 'gx': gx, 'gy': gy, 'conf': float(cf),
                        'id': k, 'hole': None, 'crop': None
                    }








                    if c == RIGHT_ID or c == LEFT_ID:
                        crop = obb_warped_crop(pil_img, corners) if USE_PERSPECTIVE_CROP else obb_rotated_crop(pil_img, cx, cy, w, h, th)
                        if crop:
                            if ORIENT_NORMALIZE: crop = crop.transpose(Image.FLIP_LEFT_RIGHT)
                            item_data['crop'] = crop
                            if c == RIGHT_ID: shoes_r.append(item_data)
                            else: shoes_l.append(item_data)
                    # [수정 완료] 모델의 ID(HOLD_ID)와 비교하여, 내부 리스트(holes)에 저장
                    elif c == HOLE_ID:
                        holes.append(item_data)








                # Matching & Processing
                assign_holes_to_shoes(shoes_r + shoes_l, holes)
                pairs = []
                if len(shoes_r) > 0 and len(shoes_l) > 0:
                    R_feats = get_feature_batch([s['crop'] for s in shoes_r], resnet, transform, DEVICE)
                    L_feats = get_feature_batch([s['crop'] for s in shoes_l], resnet, transform, DEVICE)
                    S_mat = R_feats @ L_feats.T
                    for ri, li, sc in robust_match(S_mat, USE_HUNGARIAN):
                        pairs.append((shoes_r[ri], shoes_l[li], sc))
               
                base = pil_img.copy()
                draw = ImageDraw.Draw(base)
               
                for s_r, s_l, sc in pairs:
                    draw.line([(s_r['cx'], s_r['cy']), (s_l['cx'], s_l['cy'])], fill=(255,255,0), width=3)
                   
                    r_fx, r_fz, r_vec = calculate_shoe_vector(s_r)
                    l_fx, l_fz, l_vec = calculate_shoe_vector(s_l)
                   
                    #with open(OUT_CSV, "a", newline="", encoding="utf-8") as f:
                        #csv.writer(f).writerow([
                            #fname, round(sc, 4),
                            #s_r['id'], round(s_r['conf'],3), round(r_fx,1), round(r_fz,1), round(r_vec,4),
                            #s_l['id'], round(s_l['conf'],3), round(l_fx,1), round(l_fz,1), round(l_vec,4),
                            #0,0,0,0,0,0
                        #])
                   
                    # -------------------------
                    # 2. Kinematics & 3. Control
                    # -------------------------
                    print(f" -> Calculating Kinematics for Shoe R: ({r_fx}, {r_fz})")
                    kin_res = calculate_kinematics_data(r_fx, r_fz, r_vec)
                   
                    if kin_res:
                        print(" -> Kinematics Solved! Moving Robot...")
                        execute_robot_task_sequence(kin_res)
                    else:
                        print(" -> Target Unreachable.")








                base.save(os.path.join(OUT_VIZ_DIR, f"{fname}_annotated.jpg"))
                num += 1








    except KeyboardInterrupt:
        print("Stopping...")
    finally:
        cap.release()
        cv2.destroyAllWindows()
        motor_d1.close()
        motor_d2.close()
        print("Done.")


if __name__ == "__main__":
    main()